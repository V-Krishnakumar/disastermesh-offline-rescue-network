# Res-Queue backend URL (optional).
# When using Vite dev server, /api is proxied to http://localhost:3000 by default.
# Set this only if your backend runs on a different host/port, e.g.:
# VITE_API_URL=http://localhost:3000

# Ambulance driver dashboard URL (optional).
# Your friend's Flask ambulance login/dashboard. Default: http://localhost:5000
# VITE_AMBULANCE_APP_URL=http://localhost:5000
